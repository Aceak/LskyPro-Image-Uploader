{
  "compilerOptions": {
    "target": "es2016",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noImplicitAny": true,
    "importHelpers": true,
    "lib": ["dom", "scripthost", "ESNext"],
    "rootDir": "src",
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
